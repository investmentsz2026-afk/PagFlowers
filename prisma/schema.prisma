datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price           Float
  salePrice       Float?
  saleDescription String?
  images          String[]
  stock       Int      @default(10)
  category    String
  tags        String[]
  isExclusive Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id               Int         @id @default(autoincrement())
  orderNumber      String      @unique
  clientName       String
  clientPhone      String
  clientEmail      String
  deliveryAddress  String
  deliveryDistrict String
  deliveryDate     DateTime
  deliveryTime     String
  cardMessage      String?
  total            Float
  deliveryFee      Float
  status           String      @default("PENDING") // PENDING, CONFIRMED, PREPARING, SHIPPED, DELIVERED
  paymentMethod    String      // VISA, MASTERCARD, AMEX, YAPE, PLIN, TRANSFER
  paymentStatus    String      @default("PENDING") // PENDING, PAID
  paymentReceipt   String?     // Ruta local a la imagen del comprobante
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  items            OrderItem[]
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  productName String
  price       Float
  quantity    Int
  cardMessage String?
}

model Content {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   // Store config settings as a JSON string
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
